# FormSubmit endpoint for contact form (required)
# Example: https://formsubmit.co/ajax/your-email@example.com
NEXT_PUBLIC_FORMSUBMIT_ENDPOINT=https://formsubmit.co/ajax/your-email@example.com

# Public contact details shown in footer (optional)
NEXT_PUBLIC_CONTACT_EMAIL=your-email@example.com
NEXT_PUBLIC_CONTACT_PHONE=+1234567890